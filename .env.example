# =============================================================================
# backend/.env.example  —  Rails 8 API
# =============================================================================
# Copiar a .env (desarrollo) o configurar via docker-compose / Secrets Manager
# en producción. NUNCA commitear el archivo .env real.
# =============================================================================

# ---- Rails core ----
RAILS_ENV=development
RAILS_LOG_LEVEL=info
RAILS_SERVE_STATIC_FILES=
SECRET_KEY_BASE=                  # Rails cookie/session signing. Generar con `rails secret`. >= 64 chars
JWT_SECRET_KEY=                   # HMAC para JWTs (admin + socio). >= 32 chars
PORT=3000

# ---- Postgres ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=app_perfil
DB_PASSWORD=                       # password del usuario postgres de la app
DB_POOL=5

# Alternativa: URL completa (tiene prioridad sobre DB_HOST/USER/PASSWORD si está)
DATABASE_URL=postgres://app_perfil:CHANGEME@localhost:5432/app_perfil_development

# ---- Redis ----
REDIS_URL=redis://localhost:6380/1

# ---- CORS ----
# Lista separada por coma. Sin este valor, default = localhost dev.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ---- AWS (credentials + región) ----
# En PRODUCCIÓN usar IAM role de Cloud Run, NO env vars.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=                 # AWS IAM user con permisos S3 + Rekognition (solo dev)
AWS_SECRET_ACCESS_KEY=             # idem (solo dev)
AWS_PROFILE=                       # alternativa: shared profile (opcional)

# ---- AWS S3 (fotos de socios) ----
AWS_S3_BUCKET_NAME=perfilamiento-faces
ACTIVE_STORAGE_SERVICE=local       # "local" en dev, "r2" en prod (Cloudflare R2)

# ---- AWS Rekognition ----
REKOGNITION_COLLECTION_ID=socios_stadium_users

# ---- Seed admin (solo desarrollo) ----
# El admin se crea hardcodeado en db/seeds.rb: admin@arnigon.com / Admin.123.
# NO usar en producción.