# Environment variables for development
RAILS_ENV=development
DATABASE_URL=postgres://app_perfil:dev_password@localhost:5432/app_perfil_development
REDIS_URL=redis://localhost:6379/1
JWT_SECRET_KEY=change_this_to_a_secure_secret_key_at_least_32_characters
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# AWS — Rekognition + S3 (face indexing)
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=perfilamiento-faces
REKOGNITION_COLLECTION_ID=socios_stadium_users
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY come from your shell, the
# AWS CLI profile (~/.aws/credentials), or the instance role. Do NOT commit
# real values to the repo.
